{
  "name": "Bar Assistant",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/var/www/cocktails",
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "xdebug.php-debug",
      ]
    }
  },
  "forwardPorts": [8000, 7700],
  "portsAttributes": {
    "8000": {
      "label": "Application",
      "onAutoForward": "notify"
    },
    "7700": {
      "label": "Meilisearch",
      "onAutoForward": "silent"
    }
  },
  "remoteUser": "www-data"
}
